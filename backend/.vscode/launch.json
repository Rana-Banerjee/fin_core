{
  "version": "0.2.0",
  "configurations": [

    {
      "name": "Python: Uvicorn",
      "type": "debugpy",
      "request": "launch",
      "module": "uvicorn",
      "python": "${workspaceFolder}/.venv/bin/python",
      "args": [
        "main:app",
        "--port", "8000",
        "--reload"
      ],
      "jinja": true,
      "console": "integratedTerminal"
    }
  ]
}